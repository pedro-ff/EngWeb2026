extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal.w3-center
      h1 GĂŠneros


    .w3-container
      table.w3-table-all.w3-hoverable.w3-margin-top
        tr
          th Id
          th Nome
          th Filmes
        each t in list
          tr
            td(onclick=`window.location.href='/generos/${t.id}'` style="cursor:pointer")= t.id
            td(onclick=`window.location.href='/generos/${t.id}'` style="cursor:pointer")= t.name
            td(onclick=`window.location.href='/generos/${t.id}'` style="cursor:pointer")= t.filmes