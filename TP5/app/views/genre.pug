extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Género: #{genre.id}

    .w3-container
      ul.w3-ul.w3-card-4.w3-margin
        li #[b ID:] #{genre.id}
        li #[b Nome:] #{genre.name}
        li #[b Filmes:] #{genre.filmes}
    footer.w3-container.w3-teal
      a.w3-button.w3-blue-grey.w3-margin(href="/generos") Voltar