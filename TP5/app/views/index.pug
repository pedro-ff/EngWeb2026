extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal.w3-center
      h1 Filmes


    .w3-container
      table.w3-table-all.w3-hoverable.w3-margin-top
        tr
          th Id
          th Titulo
          th Ano
          th Generos
          th Cast
        each t in list
          tr
            td(onclick=`window.location.href='/filmes/${t.id}'` style="cursor:pointer")= t.id
            td(onclick=`window.location.href='/filmes/${t.id}'` style="cursor:pointer")= t.title
            td(onclick=`window.location.href='/filmes/${t.id}'` style="cursor:pointer")= t.year
            td(onclick=`window.location.href='/filmes/${t.id}'` style="cursor:pointer")= t.genres
            td(onclick=`window.location.href='/filmes/${t.id}'` style="cursor:pointer")= t.cast
