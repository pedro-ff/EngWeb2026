extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Filme: #{film.id}

    .w3-container
      ul.w3-ul.w3-card-4.w3-margin
        li #[b ID:] #{film.id}
        li #[b Titulo:] #{film.title}
        li #[b Ano:] #{film.year}
        li #[b Elenco:] #{film.cast}
        li #[b Géneros:] #{film.genres}
    footer.w3-container.w3-teal
      a.w3-button.w3-blue-grey.w3-margin(href="/") Voltar