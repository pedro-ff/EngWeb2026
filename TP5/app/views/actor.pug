extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Ator: #{actor.id}

    .w3-container
      ul.w3-ul.w3-card-4.w3-margin
        li #[b ID:] #{actor.id}
        li #[b Nome:] #{actor.name}
        li #[b Filmes:] #{actor.filmes}
    footer.w3-container.w3-teal
      a.w3-button.w3-blue-grey.w3-margin(href="/atores") Voltar