extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 #{g.name}

    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th ID
          td= g._id
        tr
          th Nome
          td= g.name
        tr
          th Filmes
          td= g.filmes.join(', ')

    footer.w3-container.w3-light-grey
      a.w3-btn.w3-round.w3-blue-grey.w3-margin-right(href="/generos") Voltar
