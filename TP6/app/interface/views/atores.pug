extends layout

block content
  .w3-container.w3-teal
    h1 Lista de Atores

  .w3-container.w3-margin-top
    table.w3-table-all.w3-hoverable
      thead
        tr.w3-light-grey
          th ID
          th Ator
          th #Filmes
      tbody
        each a in atores
          tr
            td: a(href="/atores/" + a._id) #{a._id}
            td: a(href="/atores/" + a._id) #{a.name}
            td: a(href="/atores/" + a._id) #{a.filmes.length}

  footer.w3-container.w3-light-grey
    a.w3-btn.w3-round.w3-blue-grey.w3-margin-right(href="/") Voltar
