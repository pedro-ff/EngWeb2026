
extends layout

block content
  .w3-container.w3-teal
    h1 Lista de Filmes

  .w3-container.w3-margin-top
    table.w3-table-all.w3-hoverable
      thead
        tr.w3-light-grey
          th ID
          th Título
          th Ano
          th #Géneros
          th #Atores
      tbody
        each f in filmes
          tr
            td: a(href="/filmes/" + f._id) #{f._id}
            td: a(href="/filmes/" + f._id) #{f.title}
            td: a(href="/filmes/" + f._id) #{f.year}
            td: a(href="/filmes/" + f._id) #{f.genres.length}
            td: a(href="/filmes/" + f._id) #{f.cast.length}

  footer.w3-container.w3-light-grey
    a.w3-btn.w3-round.w3-blue-grey.w3-margin-right(href="/") Voltar
