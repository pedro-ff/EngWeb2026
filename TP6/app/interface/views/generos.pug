extends layout

block content
  .w3-container.w3-teal
    h1 Lista de Géneros

  .w3-container.w3-margin-top
    table.w3-table-all.w3-hoverable
      thead
        tr.w3-light-grey
          th ID
          th Género
          th #Filmes
      tbody
        each g in generos
          tr
            td: a(href="/generos/" + g._id) #{g._id}
            td: a(href="/generos/" + g._id) #{g.name}
            td: a(href="/generos/" + g._id) #{g.filmes.length}

  footer.w3-container.w3-light-grey
    a.w3-btn.w3-round.w3-blue-grey.w3-margin-right(href="/") Voltar
